@page "{handler?}"
@model IndexModel
@{
    ViewData["Title"] = "Basket";
}
<section class="esh-catalog-hero">
    <div class="container">
        <img class="esh-catalog-title" src="~/images/main_banner_text.png" />
    </div>
</section>

<div class="container">

    @if (Model.BasketModel.Items.Any())
    {
        <form method="post">
            <article class="esh-basket-titles row">
                <br />
                <section class="esh-basket-title col-xs-3">Product</section>
                <section class="esh-basket-title col-xs-3 hidden-lg-down"></section>
                <section class="esh-basket-title col-xs-2">Price</section>
                <section class="esh-basket-title col-xs-2">Quantity</section>
                <section class="esh-basket-title col-xs-2">Cost</section>
            </article>
            <div class="esh-catalog-items row">
                <div asp-validation-summary="All" class="text-danger"></div>
                @for (int i = 0; i < Model.BasketModel.Items.Count; i++)
                {
                    var item = Model.BasketModel.Items[i];
                    <article class="esh-basket-items row">
                        <div>
                            <section class="esh-basket-item esh-basket-item--middle col-lg-3 hidden-lg-down">
                                <img class="esh-basket-image" src="@item.PictureUrl" />
                            </section>
                            <section class="esh-basket-item esh-basket-item--middle col-xs-3">@item.ProductName</section>
                            <section class="esh-basket-item esh-basket-item--middle col-xs-2">$ @item.UnitPrice.ToString("N2")</section>
                            <section class="esh-basket-item esh-basket-item--middle col-xs-2">
                                <input type="hidden" name="@("Items[" + i + "].Id")" value="@item.Id" />

                                <div class="esh-quantity-control" data-available="@item.AvailableStock">
                                    <button type="button" class="btn esh-qty-btn" onclick="decreaseQty(@i)" id="dec-@i">-</button>
                                    <input type="number" class="esh-basket-input" min="0" name="@("Items[" + i + "].Quantity")" value="@item.Quantity" id="qty-@i" />
                                    <button type="button" class="btn esh-qty-btn" onclick="increaseQty(@i)" id="inc-@i" @(item.Quantity >= item.AvailableStock ? "disabled" : "")>+</button>
                                </div>

                                <div class="esh-catalog-stock">
                                    @{
                                        var remaining = item.AvailableStock - item.Quantity;
                                        if (item.AvailableStock == 0)
                                        {
                                            <span class="text-danger">Out of stock</span>;
                                        }
                                        else if (remaining <= 0)
                                        {
                                            <span>Only 0 left</span>;
                                        }
                                        else
                                        {
                                            <span>Only @remaining left</span>;
                                        }
                                    }
                                </div>
                            </section>
                            <section class="esh-basket-item esh-basket-item--middle esh-basket-item--mark col-xs-2">$ @Math.Round(item.Quantity * item.UnitPrice, 2).ToString("N2")</section>
                        </div>
                        <div class="row">

                        </div>
                    </article>
                }

                <div class="container">
                    <article class="esh-basket-titles esh-basket-titles--clean row">
                        <section class="esh-basket-title col-xs-10"></section>
                        <section class="esh-basket-title col-xs-2">Total</section>
                    </article>

                    <article class="esh-basket-items row">
                        <section class="esh-basket-item col-xs-10"></section>
                        <section class="esh-basket-item esh-basket-item--mark col-xs-2">$ @Model.BasketModel.Total().ToString("N2")</section>
                    </article>

                    <article class="esh-basket-items row">
                        <section class="esh-basket-item col-xs-7"></section>
                    </article>
                </div>
                <div class="row">
                    <section class="esh-basket-item col-xs-1">
                        <a asp-page="/Index" class="btn esh-basket-checkout text-white">[ Continue Shopping ]</a>
                    </section>
                    <section class="esh-basket-item col-xs-push-7 col-xs-4">

                        <button class="btn esh-basket-checkout" name="updatebutton" value="" type="submit"
                                asp-page-handler="Update">
                            [ Update ]
                        </button>
                        <a asp-page="./Checkout" class="btn esh-basket-checkout">[ Checkout ]</a>
                    </section>
                </div>
            </div>
        </form>
    }
    else
    {
        <h3 class="esh-catalog-items row">
            Basket is empty.
        </h3>

        <section class="esh-basket-item">
            <a asp-page="/Index" class="btn esh-basket-checkout text-white">[ Continue Shopping ]</a>
        </section>
    }
</div>

@section Scripts {
    <script>
        function increaseQty(index) {
            var qtyEl = document.getElementById('qty-' + index);
            var incEl = document.getElementById('inc-' + index);
            var decEl = document.getElementById('dec-' + index);
            var container = incEl.closest('.esh-quantity-control');
            var available = parseInt(container.getAttribute('data-available') || '0', 10);
            var current = parseInt(qtyEl.value || '0', 10);

            if (current < available) {
                current++;
                qtyEl.value = current;
            }

            if (current >= available) {
                incEl.setAttribute('disabled', 'disabled');
            } else {
                incEl.removeAttribute('disabled');
            }

            if (current > 0) {
                decEl.removeAttribute('disabled');
            }
        }

        function decreaseQty(index) {
            var qtyEl = document.getElementById('qty-' + index);
            var incEl = document.getElementById('inc-' + index);
            var decEl = document.getElementById('dec-' + index);
            var container = incEl.closest('.esh-quantity-control');
            var available = parseInt(container.getAttribute('data-available') || '0', 10);
            var current = parseInt(qtyEl.value || '0', 10);

            if (current > 0) {
                current--;
                qtyEl.value = current;
            }

            if (current < available) {
                incEl.removeAttribute('disabled');
            }

            if (current <= 0) {
                decEl.setAttribute('disabled', 'disabled');
            } else {
                decEl.removeAttribute('disabled');
            }
        }

        // ensure inputs are clamped on manual change
        document.addEventListener('DOMContentLoaded', function () {
            var inputs = document.querySelectorAll('.esh-quantity-control');
            inputs.forEach(function (container, index) {
                var qtyEl = container.querySelector('input[type="number"]');
                var incEl = container.querySelector('#inc-' + index);
                var decEl = container.querySelector('#dec-' + index);
                var available = parseInt(container.getAttribute('data-available') || '0', 10);

                // set initial state
                var current = parseInt(qtyEl.value || '0', 10);
                if (current >= available) {
                    var inc = container.querySelector('button[id^="inc-"]');
                    if (inc) inc.setAttribute('disabled', 'disabled');
                }
                if (current <= 0) {
                    var dec = container.querySelector('button[id^="dec-"]');
                    if (dec) dec.setAttribute('disabled', 'disabled');
                }

                qtyEl.addEventListener('change', function () {
                    var v = parseInt(qtyEl.value || '0', 10);
                    if (v < 0) v = 0;
                    if (v > available) v = available;
                    qtyEl.value = v;

                    var incBtn = container.querySelector('button[id^="inc-"]');
                    var decBtn = container.querySelector('button[id^="dec-"]');
                    if (v >= available) {
                        if (incBtn) incBtn.setAttribute('disabled', 'disabled');
                    } else {
                        if (incBtn) incBtn.removeAttribute('disabled');
                    }
                    if (v <= 0) {
                        if (decBtn) decBtn.setAttribute('disabled', 'disabled');
                    } else {
                        if (decBtn) decBtn.removeAttribute('disabled');
                    }
                });
            });
        });
    </script>
}
